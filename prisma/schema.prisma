generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MarketFrame {
  id                   String   @id @default(uuid())
  timestamp            DateTime @default(now())
  symbol               String
  price                Json
  volume               Float
  indicators           Json
  orderFlow            Json
  marketMicrostructure Json
}

model Signal {
  id                  String        @id @default(uuid())
  timestamp           DateTime      @default(now())
  symbol              String
  type                String        // 'BUY' | 'SELL' | 'HOLD'
  strength            Float
  confidence          Float
  price               Float
  reasoning           Json
  riskReward          Float
  stopLoss            Float
  takeProfit          Float
  momentumLabel       String?
  regimeState         String?
  legacyLabel         String?
  signalStrengthScore Float?
  userId              String?
  
  // === SIGNAL LIFECYCLE TRACKING ===
  // Entry state
  entryTimestamp      DateTime      @default(now())
  entryPrice          Float
  
  // Exit state (when trade closes)
  exitTimestamp       DateTime?
  exitPrice           Float?
  
  // Outcome metrics
  outcome             String?       // 'WIN' | 'LOSS' | 'BREAKEVEN' | 'OPEN'
  realizedPnL         Float?        // Actual profit/loss in base currency
  realizedPnLPercent  Float?        // Profit/loss percentage
  durationSeconds     Int?          // How long signal was active
  
  // Pattern & source info
  primaryPattern      String?       // BREAKOUT, REVERSAL, etc.
  patterns            String[]      @default([]) // Multiple patterns
  qualityScore        Float?        // 0-100 quality rating
  qualityRating       String?       // excellent|good|fair|poor|filtered
  
  // Linking to trades
  signalTrades        SignalTrade[]
  
  @@index([symbol])
  @@index([timestamp])
  @@index([outcome])
  @@index([entryTimestamp])
  @@index([exitTimestamp])
}

model SignalTrade {
  id          String   @id @default(uuid())
  signalId    String
  signal      Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  tradeId     String?  // Link to actual trade if executed
  
  // Trade outcome
  executed    Boolean  @default(false)
  executedAt  DateTime?
  outcome     String?  // 'WIN' | 'LOSS' | 'BREAKEVEN' | 'NOT_EXECUTED'
  pnl         Float?
  pnlPercent  Float?
  
  // Metadata
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  
  @@index([signalId])
  @@index([tradeId])
  @@index([outcome])
}

model SignalPerformanceStats {
  id                    String   @id @default(uuid())
  symbol                String   @unique
  
  // Signal counts
  totalSignals          Int      @default(0)
  winSignals            Int      @default(0)
  lossSignals           Int      @default(0)
  breakevenSignals      Int      @default(0)
  openSignals           Int      @default(0)
  notExecutedSignals    Int      @default(0)
  
  // Performance metrics
  winRate               Float    @default(0)     // 0-1
  profitFactor          Float    @default(0)     // wins / losses
  avgPnL                Float    @default(0)
  avgPnLPercent         Float    @default(0)
  totalPnL              Float    @default(0)
  
  // Pattern performance
  patternAccuracy       Json     @default("{}")  // { pattern: winRate }
  
  // Timeframe performance
  timeframeAccuracy     Json     @default("{}")  // { timeframe: winRate }
  
  // Quality correlation
  qualityVsWinRate      Json     @default("{}")  // { quality: winRate }
  
  lastUpdated           DateTime @default(now()) @updatedAt
  
  @@index([symbol])
  @@index([lastUpdated])
}

model Trade {
  id         String    @id @default(uuid())
  symbol     String
  side       String
  entryTime  DateTime
  exitTime   DateTime?
  entryPrice Float
  exitPrice  Float?
  quantity   Float
  pnl        Float?
  commission Float     @default(0)
  status     String    @default("OPEN")
}

model Strategy {
  id          String           @id @default(uuid())
  name        String
  description String
  riskParams  Json
  performance Json
  isActive    Boolean          @default(true)
  backtests   BacktestResult[]
}

model BacktestResult {
  id             String   @id @default(uuid())
  strategyId     String
  startDate      DateTime
  endDate        DateTime
  initialCapital Float
  finalCapital   Float
  performance    Json
  equityCurve    Json
  monthlyReturns Json
  createdAt      DateTime @default(now())
  metrics        Json
  trades         Json
  strategy       Strategy @relation(fields: [strategyId], references: [id])
}

model MarketSentiment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  data      Json
}

model PortfolioSummary {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  data      Json
}

model ScanRun {
  id         String   @id @default(uuid())
  scanId     String   @unique
  timestamp  DateTime @default(now())
  timeframe  String?
  symbolCount Int     @default(0)
  payload    Json
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  addedAt   DateTime @default(now())
  notes     String?

  @@unique([userId, symbol])
  @@index([userId])
}

model Portfolio {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings  Json     @default("[]")
  totalCost Float    @default(0)
  updatedAt DateTime @default(now()) @updatedAt
}

model User {
  id              String   @id @default(uuid())
  email           String?  @unique
  firstName       String?
  lastName        String?
  profileImageUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  preferences     UserPreference?
  apiKeys         ApiKey[]
  watchlist       Watchlist[]
  portfolio       Portfolio?
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
}

model UserPreference {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme                 String   @default("dark")
  defaultTimeframe      String   @default("1h")
  defaultExchange       String   @default("binance")
  notificationsEnabled  Boolean  @default(true)
  emailAlerts           Boolean  @default(false)
  priceAlerts           Boolean  @default(true)
  signalAlerts          Boolean  @default(true)
  soundEnabled          Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt
}

model ApiKey {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchange    String
  name        String
  apiKey      String
  apiSecret   String
  isTestnet   Boolean  @default(false)
  isActive    Boolean  @default(true)
  permissions Json     @default("[]")
  lastValidated DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([userId])
}

/// RPG Agent System
model Agent {
  id            String   @id @default(uuid())
  name          String   @unique
  type          String
  level         Int      @default(1)
  xp            Int      @default(0)
  capital       Decimal? @db.Decimal(15, 2)
  totalProfit   Decimal  @default(0) @db.Decimal(15, 2)
  winRate       Decimal  @default(0) @db.Decimal(5, 4)
  profitFactor  Decimal  @default(0) @db.Decimal(8, 4)
  sharpeRatio   Decimal  @default(0) @db.Decimal(8, 4)
  confidence    Decimal  @default(0.5) @db.Decimal(3, 2)
  mood          String   @default("focused")
  status        String   @default("active")
  skills        Json?
  abilities     Json?
  parameters    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  // relations
  trades         AgentTrade[]
  snapshots      AgentSnapshot[]
  learningEvents LearningEvent[]
  evolutionEvents EvolutionEvent[]
}

model AgentTrade {
  id           String   @id @default(uuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  symbol       String
  direction    String
  entryPrice   Decimal  @db.Decimal(15, 8)
  exitPrice    Decimal? @db.Decimal(15, 8)
  positionSize Decimal  @db.Decimal(15, 2)
  stopLoss     Decimal? @db.Decimal(15, 8)
  takeProfit   Decimal? @db.Decimal(15, 8)
  profit       Decimal? @db.Decimal(15, 2)
  profitPct    Decimal? @db.Decimal(8, 4)
  confidence   Decimal? @db.Decimal(3, 2)
  reason       String?
  marketRegime String?
  entryTime    DateTime
  exitTime     DateTime?
  status       String   @default("open")

  @@index([agentId])
  @@index([symbol])
  @@index([entryTime])
}

model AgentSnapshot {
  id          String   @id @default(uuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capital     Decimal  @db.Decimal(15, 2)
  totalProfit Decimal  @db.Decimal(15, 2)
  winRate     Decimal  @db.Decimal(5, 4)
  profitFactor Decimal @db.Decimal(8, 4)
  sharpeRatio Decimal  @db.Decimal(8, 4)
  snapshotTime DateTime @default(now())

  @@index([agentId, snapshotTime])
}

model LearningEvent {
  id             String   @id @default(uuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  parameterName  String
  oldValue       String?
  newValue       String?
  reason         String?
  tradesAnalyzed Int?     @default(0)
  confidence     Decimal? @db.Decimal(3, 2)
  eventTime      DateTime @default(now())

  @@index([agentId])
}

model EvolutionEvent {
  id         String   @id @default(uuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  eventType  String
  description String?
  eventTime  DateTime @default(now())

  @@index([agentId])
}

/// Scanner Results and Persistence
model ScanSession {
  id                String          @id @default(uuid())
  startTime         DateTime        @default(now())
  endTime           DateTime?
  status            String          @default("in_progress")
  exchanges         String[]        @default([])
  symbolCount       Int
  successCount      Int             @default(0)
  errorCount        Int             @default(0)
  avgConfidence     Float           @default(0)
  metadata          Json?
  results           ScanResult[]
  crossExchangeSignals CrossExchangeSignal[]

  @@index([startTime])
  @@index([status])
}

model ScanResult {
  id                String      @id @default(uuid())
  sessionId         String
  session           ScanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  symbol            String
  exchange          String
  signal            String      // "Strong Buy", "Buy", "Weak Buy", "Neutral", "Weak Sell", "Sell", "Strong Sell"
  strength          Float       // 0-100
  confidence        Float       // 0-1
  compositeScore    Float       // 0-100
  armSignal         String?     // "LONG" or "SHORT"
  armConfidence     Float?      // 0-1
  marketState       String?     // Market regime detection
  stateAlignment    Float?      // 0-1 alignment score
  persistenceTicks  Int?        // ARM persistence
  confirmationEdge  Boolean?    @default(false)
  price             Float
  volume24h         Float
  volumeChange      Float?
  change24h         Float?
  rsi               Float?
  macd              Float?
  macdSignal        Float?
  ema20             Float?
  ema50             Float?
  ema200            Float?
  atr               Float?
  bollingerHigh     Float?
  bollingerLow      Float?
  timestamp         DateTime    @default(now())

  @@index([sessionId])
  @@index([symbol])
  @@index([exchange])
  @@index([timestamp])
  @@unique([sessionId, symbol, exchange])
}

model CrossExchangeSignal {
  id                String      @id @default(uuid())
  sessionId         String
  session           ScanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  symbol            String
  signalType        String      // "CONSENSUS", "DIVERGENCE", "ARBITRAGE", "ACCUMULATION", "DISTRIBUTION"
  confidence        Float       // 0-1
  exchanges         String[]    // Exchanges involved
  description       String?
  avgCompositeScore Float?      // Average score across exchanges
  priceRange        Json?       // { min, max, diff } for arbitrage detection
  volumeMetrics     Json?       // Volume analysis data
  timestamp         DateTime    @default(now())

  @@index([sessionId])
  @@index([symbol])
  @@index([signalType])
  @@index([timestamp])
}

model ScannerSignalStats {
  id                String   @id @default(uuid())
  symbol            String   @unique
  totalScans        Int      @default(0)
  avgConfidence     Float    @default(0)
  strongBuyCount    Int      @default(0)
  buyCount          Int      @default(0)
  neutralCount      Int      @default(0)
  sellCount         Int      @default(0)
  strongSellCount   Int      @default(0)
  topExchange       String?
  trend             String?  // "bullish", "bearish", "neutral"
  lastUpdated       DateTime @default(now()) @updatedAt
  metadata          Json?

  @@index([symbol])
  @@index([lastUpdated])
}

