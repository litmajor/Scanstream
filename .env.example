# ============================================================================
# FEATURE FLAGS ENVIRONMENT CONFIGURATION
# ============================================================================
# Format: FEATURE_FLAG_<FLAG_NAME>=true|false
# All flags default to values in server/config/featureFlags.ts
# Environment variables here OVERRIDE defaults at startup

# ============================================================================
# STRATEGY FEATURES
# ============================================================================
FEATURE_FLAG_TRADE_DURATION_PREDICTOR=false
FEATURE_FLAG_PYRAMID_STRATEGY=false
FEATURE_FLAG_ADAPTIVE_HOLDING_PERIOD=false
FEATURE_FLAG_REGIME_AWARE_TRADING=false

# ============================================================================
# AGENT CORE SERVICES
# ============================================================================
FEATURE_FLAG_AGENT_LIFECYCLE=true
FEATURE_FLAG_AGENT_ARENA=true
FEATURE_FLAG_AGENT_CLUSTERING=true
FEATURE_FLAG_AGENT_SYNERGY=false
FEATURE_FLAG_AGENT_ACHIEVEMENT_SYSTEM=false
FEATURE_FLAG_AGENT_PORTFOLIO_MANAGER=false

# ============================================================================
# AGENT SPECIALIST ABILITIES
# ============================================================================
# Core specialist abilities (enabled by default)
FEATURE_FLAG_AGENT_ABILITY_BREAKOUT_HUNTER=true
FEATURE_FLAG_AGENT_ABILITY_REVERSAL_MASTER=true
FEATURE_FLAG_AGENT_ABILITY_TREND_RIDER=true
FEATURE_FLAG_AGENT_ABILITY_SUPPORT_SNIPER=true

# Physics-based specialist abilities
FEATURE_FLAG_AGENT_ABILITY_PHYSICS_FLOW=false
FEATURE_FLAG_AGENT_ABILITY_PHYSICS_VFMD=false

# Prediction specialist abilities
FEATURE_FLAG_AGENT_ABILITY_ML_ORACLE=false
FEATURE_FLAG_AGENT_ABILITY_MARKET_ORACLE=false

# Analysis specialist abilities
FEATURE_FLAG_AGENT_ABILITY_VOLUME_VERIFIER=false
FEATURE_FLAG_AGENT_ABILITY_EXIT_ORCHESTRATOR=false
FEATURE_FLAG_AGENT_ABILITY_OPPOSITION_READER=false
FEATURE_FLAG_AGENT_ABILITY_MICROSTRUCTURE_SPECIALIST=false
FEATURE_FLAG_AGENT_ABILITY_FEATURE_ENGINEER=false

# ============================================================================
# AGENT LEVELED ABILITIES
# ============================================================================
# Abilities that unlock as agents gain levels (enabled by default)
FEATURE_FLAG_AGENT_ABILITY_DYNAMIC_POSITION_SIZING=true
FEATURE_FLAG_AGENT_ABILITY_INTELLIGENT_EXITS=true
FEATURE_FLAG_AGENT_ABILITY_MULTI_TIMEFRAME_CONFIRMATION=true
FEATURE_FLAG_AGENT_ABILITY_REGIME_ADAPTATION=true
FEATURE_FLAG_AGENT_ABILITY_VELOCITY_BASED_TARGETS=true
FEATURE_FLAG_AGENT_ABILITY_CORRELATION_HEDGING=true
FEATURE_FLAG_AGENT_ABILITY_PATTERN_DISCOVERY=true
FEATURE_FLAG_AGENT_ABILITY_PORTFOLIO_OPTIMIZATION=true
FEATURE_FLAG_AGENT_ABILITY_STRATEGY_CREATION=false

# ============================================================================
# RPG SYSTEM FEATURES
# ============================================================================
FEATURE_FLAG_COMMANDER_APPROVAL=false
FEATURE_FLAG_DAILY_BRIEFING=false
FEATURE_FLAG_INFORMATION_CHANNELS=false
FEATURE_FLAG_ONLINE_LEARNING_SYSTEM=false

# ============================================================================
# ANALYSIS FEATURES
# ============================================================================
FEATURE_FLAG_PHYSICS_VALIDATION=true
FEATURE_FLAG_ML_LSTM_CONSENSUS=true
FEATURE_FLAG_BAYESIAN_BELIEF_UPDATE=false
FEATURE_FLAG_FLOW_FIELD_ANALYTICS=true
FEATURE_FLAG_CROSS_EXCHANGE_AGGREGATION=false

# ============================================================================
# EXPERIMENTAL FEATURES
# ============================================================================
FEATURE_FLAG_ADVANCED_RISK_METRICS=false
FEATURE_FLAG_NEURAL_NETWORK_SIGNALS=false
FEATURE_FLAG_PORTFOLIO_OPTIMIZATION=false

# ============================================================================
# ADMIN FEATURES
# ============================================================================
FEATURE_FLAG_FEATURE_FLAG_UI=false
FEATURE_FLAG_DEBUG_LOGGING=false
FEATURE_FLAG_METRICS_COLLECTION=true

